{
  "entities": {
    "Comment": {
      "title": "Comment",
      "description": "A user comment or feedback for the candidate",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the person commenting"
        },
        "village": {
          "type": "string",
          "description": "Village of the person"
        },
        "mobile": {
          "type": "string",
          "description": "Mobile number (masked)"
        },
        "text": {
          "type": "string",
          "description": "The comment text"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the comment was created"
        }
      },
      "required": ["name", "village", "mobile", "text", "createdAt"]
    }
  },
  "firestore": {
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Collection of user comments"
    }
  }
}
